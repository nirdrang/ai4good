{
  "prd_path": ".taskmaster/docs/prd.md",
  "validator_cmd": ["python", ".claude/skills/prd-taskmaster/script.py", "validate-prd", "--input", ".taskmaster/docs/prd.md"],
  "evaluator": {
    "vendor": "codex",
    "cmd_prefix": ["codex", "exec", "--sandbox", "read-only", "--skip-git-repo-check", "-c", "model_reasoning_effort=xhigh"],
    "timeout_seconds": 1800,
    "json_retry": 1
  },
  "generator": {
    "enabled": false,
    "note": "Generation stays disabled until the evaluator baseline has been reviewed by the founder (run-1 scoping decision, 2026-07-05).",
    "local_model": "claude-sonnet-5",
    "escalation_model": "claude-opus-4-8",
    "distiller_model": "claude-haiku-4-5-20251001"
  },
  "caps": {
    "max_iterations": 6,
    "max_sections_per_iteration": 3,
    "max_model_calls_per_run": 40,
    "baseline_batch_size": 8
  },
  "plateau": {
    "rule": "blocking-critique count unchanged AND net pairwise verdicts <= +1 across 2 consecutive iterations",
    "epsilon_rounds": 2
  },
  "gate": {
    "leaf_heading_patterns": ["^#### REQ-", "^### Story "],
    "required_blocks": ["Acceptance Criteria", "Dependencies"],
    "exempt_leaves": ["REQ-005.5", "REQ-017", "REQ-018", "REQ-019", "REQ-020", "REQ-022"],
    "terminology_watch": [
      "TaskMaster", "tasks\\.json", "usage_poll", "anthropic_workspace", "anthropic_key",
      "mcp\\.ai4good\\.dev", "tok_workspace", "paused", "channel_message", "linear_workspace_setup"
    ],
    "decision_marker": "\\[DECISION: OD-\\d+"
  },
  "rubric": {
    "dimensions": {
      "decomposability": 30,
      "ac_testability": 25,
      "dependency_completeness": 15,
      "invariant_and_ledger_consistency": 15,
      "unmade_decision_detection": 15
    }
  }
}
